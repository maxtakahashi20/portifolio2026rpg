# API Go (rode na raiz: npm run server  ou  go run ./cmd/api)
ADMIN_SECRET=troque-por-uma-frase-longa-e-secreta
PORT=8787

# Caminho opcional do JSON de projetos (padrão: server/data/projects.json)
# PROJECTS_DATA_PATH=

# Frontend — URL absoluta da API em produção (ex.: https://portfolio-api-xxxx.onrender.com)
# Em dev deixe vazio para usar o proxy do Vite (/api → localhost:8787)
# VITE_API_URL=
#
# Deploy API: render.yaml na raiz usa runtime Go nativo no Render (sem Docker obrigatório).
# Dockerfile na raiz continua opcional para build local/outros hosts.
# Defina ADMIN_SECRET no painel; em produção configure VITE_API_URL no build do site estático.
