# API Go (rode na raiz: npm run server  ou  go run ./cmd/api)
ADMIN_SECRET=troque-por-uma-frase-longa-e-secreta
PORT=8787

# Caminho opcional do JSON de projetos (padrão: server/data/projects.json)
# PROJECTS_DATA_PATH=

# Frontend — URL absoluta da API em produção (SEM barra no final).
# Em dev deixe vazio para usar o proxy do Vite (/api → localhost:8787).
# VITE_API_URL=https://portfolio2026rpg.onrender.com
#
# Vercel / Netlify: crie VITE_API_URL no painel (Production) com a URL do Render e faça
# REDEPLOY — o Vite embute essa variável na hora do build, não em runtime.
#
# Deploy API: render.yaml (runtime Go); ADMIN_SECRET no painel do Render.
